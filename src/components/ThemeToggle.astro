---
// src/components/ThemeToggle.astro
---
<button 
  id="theme-toggle" 
  class="relative inline-flex items-center justify-center w-12 h-12 text-gray-600 bg-white/80 backdrop-blur-sm rounded-full shadow-lg dark:text-gray-300 dark:bg-gray-800/80 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary transition-all duration-300" 
  aria-label="Cambiar entre modo claro y oscuro"
  title="Cambiar tema"
>
  <!-- Icono de sol (modo claro) -->
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    class="absolute w-6 h-6 transition-all duration-300 transform scale-100 opacity-100 dark:scale-0 dark:opacity-0" 
    fill="none" 
    viewBox="0 0 24 24" 
    stroke="currentColor" 
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
  </svg>
  
  <!-- Icono de luna (modo oscuro) -->
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    class="absolute w-6 h-6 transition-all duration-300 transform scale-0 opacity-0 dark:scale-100 dark:opacity-100" 
    fill="none" 
    viewBox="0 0 24 24" 
    stroke="currentColor" 
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
  </svg>
</button>
